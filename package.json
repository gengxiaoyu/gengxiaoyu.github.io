{
  "name": "toolbox-website",
  "version": "1.0.0",
  "description": "炫酷工具箱网站 - 专业工具下载平台",
  "main": "index.html",
  "scripts": {
    "dev": "python -m http.server 8000",
    "start": "python -m http.server 8000",
    "compress:css": "cleancss -o css/main.min.css css/main.css",
    "compress:js": "uglifyjs js/main.js -o js/main.min.js -c -m",
    "compress": "npm run compress:css && npm run compress:js"
  },
  "keywords": [
    "toolbox",
    "tools",
    "download",
    "website"
  ],
